+                // dynamic, so leak the (small, session-lived) binding name.
+                let name: &'static str =
+                    Box::leak(format!("plugin-keymap:{command_id}").into_boxed_str());
+                let binding = EditableBinding::new(
+                    name,
+                    title,
+                    WorkspaceAction::RunPluginCommand(command_id),
+                )
