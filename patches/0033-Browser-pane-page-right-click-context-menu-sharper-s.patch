+/// Opens `url` in the system default browser (macOS `open`).
+fn open_in_system_browser(url: &str) {
+    if let Err(e) = std::process::Command::new("open").arg(url).spawn() {
+        log::warn!("[omw-browser] failed to open {url} in system browser: {e}");
+    }
+}
